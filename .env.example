# Copy to .env for LOCAL dev only. In prod, Doppler injects these.
# NEVER commit a real .env. See doppler.md for the canonical list.

# --- Runtime ---
FMML_ENV=local                # local | production
LOG_LEVEL=INFO

# --- Anthropic (clue & persona generation) ---
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Supabase ---
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=xxx

# --- X API (single developer app) ---
X_API_KEY=xxx
X_API_SECRET=xxx
X_BEARER_TOKEN=xxx
# Main account @FindingMemeland OAuth tokens
X_MAIN_ACCESS_TOKEN=xxx
X_MAIN_ACCESS_SECRET=xxx
# Persona tokens are stored per-account in the DB / Doppler as X_PERSONA_<id>_*

# --- Base chain ---
BASE_RPC_URL=https://mainnet.base.org
FMML_TOKEN_ADDRESS=            # 0x... — filled after Clanker deploy (checklist step 20)
HOT_WALLET_PRIVATE_KEY=        # EOA, holds <= 2 hunts of prizes
PAYOUT_CAP_FMML=               # hardcoded per-hunt ceiling (token units)

# --- Telegram (approval queue + admin commands) ---
TELEGRAM_BOT_TOKEN=xxx
TELEGRAM_ADMIN_CHAT_ID=        # hardcoded; only this chat can trigger hunts

# --- Game parameters (overridable per hunt batch) ---
PRIZE_USD_MIN=200
PRIZE_USD_MAX=500
INTEGRITY_SALT=                # random secret; revealed in Winner Announcement
